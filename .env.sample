# ── NVIDIA NIM (via build.nvidia.com) ──────────────────────────────────────────
# Used for: LLM inference + Embeddings (OpenAI-compatible endpoint)
# Get your key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Neo4j ──────────────────────────────────────────────────────────────────────
# For local Neo4j Desktop:
#   NEO4J_URI=bolt://localhost:7687
#   NEO4J_USERNAME=neo4j
#   NEO4J_PASSWORD=your-local-password
#
# For Neo4j Aura (cloud):
#   NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
#   NEO4J_USERNAME=<your-username>
#   NEO4J_PASSWORD=<your-password>
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── App ────────────────────────────────────────────────────────────────────────
APP_PORT=7777
APP_HOST=0.0.0.0

# ── LanceDB (vector store) ─────────────────────────────────────────────────────
LANCEDB_URI=tmp/lancedb

# ── SQLite (session store) ─────────────────────────────────────────────────────
SQLITE_DB_FILE=tmp/smarthome.db
